{
    "name": "travisobregon/filament-diffs",
    "description": "Render visual diffs between Eloquent model versions in Filament.",
    "keywords": [
        "travisobregon",
        "laravel",
        "filamentphp",
        "filament",
        "filament-plugin",
        "filament-diffs"
    ],
    "homepage": "https://github.com/travisobregon/filament-diffs",
    "support": {
        "issues": "https://github.com/travisobregon/filament-diffs/issues",
        "source": "https://github.com/travisobregon/filament-diffs"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Travis Obregon",
            "email": "travisobregon@icloud.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "filament/filament": "^5.0",
        "spatie/laravel-package-tools": "^1.15.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.7|^4.0",
        "pestphp/pest-plugin-arch": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "pestphp/pest-plugin-livewire": "^3.0|^4.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "TravisObregon\\FilamentDiffs\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TravisObregon\\FilamentDiffs\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "phpstan analyse",
        "lint": "pint",
        "refactor": "rector",
        "test": "pest",
        "test:lint": "pint --test",
        "test:refactor": "rector --dry-run"
    },
    "extra": {
        "laravel": {
            "providers": [
                "TravisObregon\\FilamentDiffs\\FilamentDiffsServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}